# ---- LLM (OpenAI-compatible) ----
# Mặc định trỏ Ollama chạy nội bộ. Không set cũng chạy được: app tự chuyển
# "chế độ cơ bản" (vẫn lọc & gợi ý sản phẩm thật, chỉ khác phần diễn đạt).
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:7b

# Trong Docker KHÔNG dùng localhost (đó là chính container). Trỏ ra host/LAN:
# LLM_BASE_URL=http://host.docker.internal:11434/v1
# LLM_BASE_URL=http://192.168.1.50:11434/v1

# Ví dụ dùng API ngoài thay cho Ollama:
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# ---- Bí mật môi trường trình diễn ----
# Bản trình diễn MỞ: KHÔNG có mã truy cập chung. Ai mở trang cũng chat được ngay.
#
# Sinh giá trị ngẫu nhiên: openssl rand -hex 16

# Mã quản trị — CHỈ dùng để xoá toàn bộ dữ liệu trình diễn. Không phát cho người dùng.
# Chưa đặt thì cổng quản trị TỪ CHỐI tất cả (đóng an toàn).
DEMO_ADMIN_SECRET=

# Bí mật còn lại là mã riêng từng phiên: máy chủ tự sinh lúc tạo phiên, không cấu
# hình ở đây, chỉ lưu ở dạng băm. Nó chặn người khác đọc/xoá phiên của mình khi chỉ
# biết số phiên — nên vẫn bắt buộc dù bản trình diễn đã mở.

# Mã bản phát hành, ghi vào mọi ảnh chụp quyết định để tái hiện về sau.
RELEASE_VERSION=demo@v0

# ---- Dữ liệu ----
# data/may_lanh.json được import tĩnh vào bản build (deploy tất định).
# Muốn cập nhật catalog: chạy `npm run data:extract` rồi build lại.
